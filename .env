# Copy to .env and edit as needed. Compose will pick it up automatically.

# ---- Database ----
DB_NAME=washhelper
DB_USERNAME=root
DB_ROOT_PASSWORD=123456
DB_PORT=3306

# ---- Redis ----
# Leave REDIS_PASSWORD empty to disable auth (matches the default backend config).
REDIS_PASSWORD=
REDIS_PORT=6379

# ---- Backend ----
BACKEND_PORT=8099
APP_API_KEY=your-secret-api-key-here
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
LOG_SQL_LEVEL=info
LOG_SQL_BIND_LEVEL=info
JAVA_OPTS=-XX:MaxRAMPercentage=70

# ---- Frontend dev server (only used with `--profile dev`) ----
FRONTEND_PORT=9528